{
  "publisher": "simonhe",
  "name": "lazy-install",
  "displayName": "Lazy Install - Auto Install Missing Packages",
  "version": "0.0.13",
  "packageManager": "pnpm@8.15.9",
  "description": "VS Code extension that detects missing npm packages from import statements and installs them with one click using npm, pnpm, yarn, or ni.",
  "author": "Simon He <https://github.com/Simon-He95>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/Simon-He95",
  "homepage": "https://github.com/Simon-He95/lazy-install#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Simon-He95/lazy-install"
  },
  "bugs": {
    "url": "https://github.com/Simon-He95/lazy-install/issues"
  },
  "sponsor": {
    "url": "https://github.com/Simon-He95/sponsor"
  },
  "keywords": [
    "npm",
    "pnpm",
    "yarn",
    "ni",
    "package",
    "packages",
    "dependency",
    "dependencies",
    "missing-packages",
    "missing-dependencies",
    "install",
    "auto-install",
    "one-click-install",
    "import",
    "codelens",
    "monorepo",
    "workspace",
    "javascript",
    "typescript",
    "react",
    "vue",
    "node",
    "vscode",
    "vscode-extension"
  ],
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "main": "./dist/index.js",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:vue"
  ],
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "lazy-install",
      "properties": {
        "lazy-install.way": {
          "type": "string",
          "default": "ni",
          "enum": [
            "ni",
            "npm",
            "pnpm",
            "yarn"
          ],
          "description": "Choose how to install it, such as ni, npm, pnpm, yarn, default: ni"
        }
      }
    }
  },
  "scripts": {
    "dev": "pnpm build --watch",
    "test": "vitest",
    "build": "tsup src/index.ts --external vscode",
    "pack": "vsce package --no-dependencies",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix",
    "publish": "vsce publish --no-dependencies",
    "typecheck": "tsc --noEmit",
    "release": "bumpp && pnpm run publish"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.15.0",
    "@types/node": "^18.19.112",
    "@types/vscode": "1.95.0",
    "@vscode-use/utils": "^0.1.59",
    "@vscode/vsce": "^3.5.0",
    "bumpp": "^9.11.1",
    "eslint": "^9.29.0",
    "esno": "^0.16.3",
    "find-up": "^7.0.0",
    "lazy-js-utils": "^0.1.45",
    "tsup": "^6.7.0",
    "typescript": "^5.8.3",
    "vitest": "^0.29.8",
    "yamljs": "^0.3.0"
  }
}
